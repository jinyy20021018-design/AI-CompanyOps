#!/bin/bash
set -uo pipefail

CLI_DIR="$(cd "$(dirname "$0")/.." && pwd)"
SETUP_MARKER="$CLI_DIR/.coagent-setup-done"

_find_honcho() {
  [ -n "${COAGENT_HONCHO_DIR:-}" ] && [ -d "$COAGENT_HONCHO_DIR" ] && echo "$COAGENT_HONCHO_DIR" && return
  [ -d "$CLI_DIR/../honcho" ] && echo "$(cd "$CLI_DIR/../honcho" && pwd)" && return
  [ -d "$CLI_DIR/../../honcho" ] && echo "$(cd "$CLI_DIR/../../honcho" && pwd)" && return
  local p="$CLI_DIR"
  for _ in 1 2 3; do
    p="$(dirname "$p")"
    for d in "$p"/*/; do
      [ -f "${d}src/main.py" ] && [ -f "${d}docker-compose.local.yml" ] && echo "$(cd "$d" && pwd)" && return
    done
  done
  echo ""
}
HONCHO_DIR="$(_find_honcho)"

# в”Ђв”Ђ Colors в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
CYAN='\033[0;36m'
BLUE='\033[0;34m'
MAGENTA='\033[0;35m'
DIM='\033[2m'
BOLD='\033[1m'
RESET='\033[0m'

log()  { echo -e "  ${CYAN}в–ё${RESET} $1"; }
ok()   { echo -e "  ${GREEN}вњ“${RESET} $1"; }
fail() { echo -e "  ${RED}вњ—${RESET} $1"; }
warn() { echo -e "  ${YELLOW}!${RESET} $1"; }
head() { echo -e "\n${BOLD}$1${RESET}"; }

# в”Ђв”Ђ Spinner в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
spin() {
  local msg="$1"; shift
  local pid
  "$@" &>/dev/null &
  pid=$!
  local frames=("в ‹" "в ™" "в №" "в ё" "в ј" "в ґ" "в ¦" "в §" "в ‡" "в Џ")
  local i=0
  while kill -0 "$pid" 2>/dev/null; do
    printf "\r  ${CYAN}${frames[$i]}${RESET} %s" "$msg"
    i=$(( (i + 1) % 10 ))
    sleep 0.1
  done
  wait "$pid" 2>/dev/null
  local rc=$?
  printf "\r"
  [ $rc -eq 0 ] && ok "$msg" || fail "$msg"
  return $rc
}

# в”Ђв”Ђ Banner в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
banner() {
  echo ""
  echo -e "${BOLD}${CYAN}   в–€в–€в–€в–€в–€в–€в•— в–€в–€в–€в–€в–€в–€в•—  в–€в–€в–€в–€в–€в•—  в–€в–€в–€в–€в–€в–€в•— в–€в–€в–€в–€в–€в–€в–€в•—в–€в–€в–€в•—   в–€в–€в•—в–€в–€в–€в–€в–€в–€в–€в–€в•—${RESET}"
  echo -e "${BOLD}${CYAN}  в–€в–€в•”в•ђв•ђв•ђв•ђв•ќв–€в–€в•”в•ђв•ђв•ђв–€в–€в•—в–€в–€в•”в•ђв•ђв–€в–€в•—в–€в–€в•”в•ђв•ђв•ђв•ђв•ќ в–€в–€в•”в•ђв•ђв•ђв•ђв•ќв–€в–€в–€в–€в•—  в–€в–€в•‘в•љв•ђв•ђв–€в–€в•”в•ђв•ђв•ќ${RESET}"
  echo -e "${BOLD}${CYAN}  в–€в–€в•‘     в–€в–€в•‘   в–€в–€в•‘в–€в–€в–€в–€в–€в–€в–€в•‘в–€в–€в•‘  в–€в–€в–€в•—в–€в–€в–€в–€в–€в•—  в–€в–€в•”в–€в–€в•— в–€в–€в•‘   в–€в–€в•‘   ${RESET}"
  echo -e "${BOLD}${CYAN}  в–€в–€в•‘     в–€в–€в•‘   в–€в–€в•‘в–€в–€в•”в•ђв•ђв–€в–€в•‘в–€в–€в•‘   в–€в–€в•‘в–€в–€в•”в•ђв•ђв•ќ  в–€в–€в•‘в•љв–€в–€в•—в–€в–€в•‘   в–€в–€в•‘   ${RESET}"
  echo -e "${BOLD}${CYAN}  в•љв–€в–€в–€в–€в–€в–€в•—в•љв–€в–€в–€в–€в–€в–€в•”в•ќв–€в–€в•‘  в–€в–€в•‘в•љв–€в–€в–€в–€в–€в–€в•”в•ќв–€в–€в–€в–€в–€в–€в–€в•—в–€в–€в•‘ в•љв–€в–€в–€в–€в•‘   в–€в–€в•‘   ${RESET}"
  echo -e "${BOLD}${CYAN}   в•љв•ђв•ђв•ђв•ђв•ђв•ќ в•љв•ђв•ђв•ђв•ђв•ђв•ќ в•љв•ђв•ќ  в•љв•ђв•ќ в•љв•ђв•ђв•ђв•ђв•ђв•ќ в•љв•ђв•ђв•ђв•ђв•ђв•ђв•ќв•љв•ђв•ќ  в•љв•ђв•ђв•ђв•ќ   в•љв•ђв•ќ   ${RESET}"
  echo ""
  echo -e "  ${DIM}Multi-agent terminal canvas with semantic memory${RESET}"
  echo ""
}

# в”Ђв”Ђ First-run wizard в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
do_wizard() {
  banner

  echo -e "${BOLD}  Welcome! Let's get you set up.${RESET}"
  echo -e "  ${DIM}This takes about 2 minutes. You'll only do this once.${RESET}"
  echo ""
  sleep 1

  # Step 1: Check prerequisites
  head "  Step 1/5  Checking prerequisites"
  sleep 0.3

  local missing=0
  command -v node &>/dev/null && ok "Node.js $(node -v)" || { fail "Node.js not found вЂ” install from https://nodejs.org"; missing=1; }
  command -v docker &>/dev/null && ok "Docker $(docker --version 2>/dev/null | grep -oE '[0-9]+\.[0-9]+\.[0-9]+')" || { fail "Docker not found вЂ” install Docker Desktop"; missing=1; }

  if [ ! -d "$HONCHO_DIR" ]; then
    fail "Honcho server not found"
    echo -e "    ${DIM}Expected at: ../honcho (sibling of this directory)${RESET}"
    echo -e "    ${DIM}Or set: export COAGENT_HONCHO_DIR=/path/to/honcho${RESET}"
    missing=1
  else
    ok "Honcho server found"
  fi

  [ $missing -eq 1 ] && { echo ""; fail "Fix the above and try again."; exit 1; }

  # Step 2: Claude Code auth
  head "  Step 2/5  Anthropic authentication"
  sleep 0.3

  local has_claude_auth=0
  if security find-generic-password -s "Claude Code-credentials" -w &>/dev/null; then
    local token_preview=$(security find-generic-password -s "Claude Code-credentials" -w 2>/dev/null | python3 -c "import sys,json; t=json.loads(sys.stdin.read())['claudeAiOauth']; print(f'sk-ant-...{t[\"accessToken\"][-8:]} ({t[\"subscriptionType\"]})')" 2>/dev/null)
    ok "Claude Code logged in  ${DIM}$token_preview${RESET}"
    has_claude_auth=1
  else
    warn "Claude Code not detected"
    echo -e "    ${DIM}Log in to Claude Code first: ${BOLD}claude${RESET}"
    echo -e "    ${DIM}CoAgent uses your Claude Code session for LLM calls (no separate API key needed).${RESET}"
    echo ""
    echo -ne "  ${YELLOW}Continue without Claude auth? [y/N]:${RESET} "
    read -r answer
    [[ "$answer" =~ ^[Yy] ]] || exit 0
  fi

  # Step 3: Gemini API key
  head "  Step 3/5  Embedding model"
  sleep 0.3

  local gemini_key=""
  if [ -n "$HONCHO_DIR" ] && [ -f "$HONCHO_DIR/.env" ]; then
    gemini_key=$(grep "^LLM_GEMINI_API_KEY=" "$HONCHO_DIR/.env" 2>/dev/null | cut -d= -f2)
  fi

  if [ -n "$gemini_key" ] && [ "$gemini_key" != "" ] && [ "$gemini_key" != "your-key-here" ]; then
    ok "Gemini API key configured  ${DIM}${gemini_key:0:10}...${RESET}"
  else
    echo -e "  ${DIM}CoAgent needs an embedding model for semantic memory.${RESET}"
    echo -e "  ${DIM}Google Gemini is free вЂ” no credit card needed.${RESET}"
    echo ""
    echo -e "  ${BOLD}Get your key:${RESET} ${CYAN}https://aistudio.google.com/apikey${RESET}"
    echo ""
    echo -ne "  ${YELLOW}Paste your Gemini API key (or Enter to skip):${RESET} "
    read -r input_key
    if [ -n "$input_key" ]; then
      gemini_key="$input_key"
      ok "Gemini key saved"
    else
      warn "Skipped вЂ” semantic search won't work without embeddings"
      echo -e "    ${DIM}Add later: edit $HONCHO_DIR/.env${RESET}"
    fi
  fi

  # Step 4: Install dependencies
  head "  Step 4/5  Installing dependencies"
  sleep 0.3

  # uv
  UV="${HOME}/.local/bin/uv"
  if [ ! -x "$UV" ] && ! command -v uv &>/dev/null; then
    spin "Installing uv (Python package manager)" curl -LsSf https://astral.sh/uv/install.sh -o /tmp/uv-install.sh
    bash /tmp/uv-install.sh &>/dev/null
    ok "uv installed"
  else
    [ ! -x "$UV" ] && UV="$(command -v uv)"
    ok "uv ready"
  fi

  # npm
  if [ ! -d "$CLI_DIR/backend/node_modules" ]; then
    spin "Installing backend dependencies" bash -c "cd '$CLI_DIR' && npm install --silent 2>/dev/null && cd backend && npm install --silent 2>/dev/null && cd ../frontend && npm install --silent 2>/dev/null"
  else
    ok "Node dependencies ready"
  fi

  # python
  if [ -n "$HONCHO_DIR" ] && [ ! -d "$HONCHO_DIR/.venv" ]; then
    spin "Installing Honcho Python dependencies" bash -c "cd '$HONCHO_DIR' && '$UV' sync --quiet 2>/dev/null"
  else
    ok "Python dependencies ready"
  fi

  # Step 5: Configure .env
  head "  Step 5/5  Writing configuration"
  sleep 0.3

  if [ -n "$HONCHO_DIR" ]; then
    # Create or update .env
    if [ ! -f "$HONCHO_DIR/.env" ]; then
      cp "$CLI_DIR/.env.example" "$HONCHO_DIR/.env"
    fi

    # Inject Gemini key
    if [ -n "$gemini_key" ]; then
      if grep -q "^LLM_GEMINI_API_KEY=" "$HONCHO_DIR/.env"; then
        sed -i '' "s|^LLM_GEMINI_API_KEY=.*|LLM_GEMINI_API_KEY=$gemini_key|" "$HONCHO_DIR/.env"
      else
        echo "LLM_GEMINI_API_KEY=$gemini_key" >> "$HONCHO_DIR/.env"
      fi
    fi

    # Inject Claude token
    if [ $has_claude_auth -eq 1 ]; then
      bash "$HONCHO_DIR/scripts/refresh-oauth-token.sh" 2>/dev/null
    fi

    ok "Configuration saved"
  fi

  # Mark setup done
  touch "$SETUP_MARKER"

  echo ""
  echo -e "  ${BOLD}${GREEN}Setup complete!${RESET}"
  echo ""
  sleep 0.5

  # Now start everything
  do_start_services
}

# в”Ђв”Ђ Usage в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
usage() {
  echo -e "${BOLD}CoAgent${RESET} вЂ” Multi-agent terminal canvas with semantic memory"
  echo ""
  echo "Usage: coagent [command]"
  echo ""
  echo "Commands:"
  echo "  (default)   Start all services"
  echo "  stop        Stop all services"
  echo "  status      Show service health"
  echo "  restart     Stop then start"
  echo "  logs        Tail all service logs"
  echo "  open        Open the UI in browser"
  echo "  setup       Re-run first-time setup"
  echo ""
}

# в”Ђв”Ђ UV path в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
UV="${HOME}/.local/bin/uv"
[ ! -x "$UV" ] && UV="$(command -v uv 2>/dev/null || echo "")"

# в”Ђв”Ђ Start services в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
do_start_services() {
  banner
  echo -e "  ${DIM}Starting services...${RESET}"

  # Refresh OAuth token
  if [ -f "$HONCHO_DIR/scripts/refresh-oauth-token.sh" ]; then
    bash "$HONCHO_DIR/scripts/refresh-oauth-token.sh" 2>/dev/null
  fi

  # Docker
  if ! docker info &>/dev/null; then
    fail "Docker is not running. Start Docker Desktop first."
    exit 1
  fi
  cd "$HONCHO_DIR"
  docker compose -f docker-compose.local.yml up -d 2>&1 | grep -E "Started|Running|Creating" | while read line; do log "$line"; done
  for i in {1..20}; do
    PG=$(docker inspect --format='{{.State.Health.Status}}' honcho-database-1 2>/dev/null || echo "waiting")
    RD=$(docker inspect --format='{{.State.Health.Status}}' honcho-redis-1 2>/dev/null || echo "waiting")
    [ "$PG" = "healthy" ] && [ "$RD" = "healthy" ] && break
    sleep 1
  done
  ok "Postgres + Redis"

  # DB migrations (first run after Docker)
  if [ -f "$HONCHO_DIR/alembic.ini" ]; then
    cd "$HONCHO_DIR" && "$UV" run alembic upgrade head &>/dev/null
  fi

  # Honcho API
  lsof -ti :8000 | xargs kill -9 2>/dev/null || true
  sleep 0.5
  cd "$HONCHO_DIR"
  nohup "$UV" run fastapi dev src/main.py --port 8000 > /tmp/coagent-honcho-api.log 2>&1 &
  for i in {1..20}; do
    curl -sf http://localhost:8000/v3/workspaces -X POST -H "Content-Type: application/json" -d '{"id":"terminal-canvas"}' > /dev/null 2>&1 && break
    sleep 1
  done
  ok "Honcho API"

  # Deriver
  pkill -f "src.deriver" 2>/dev/null || true
  sleep 0.5
  DERIVER_FLUSH_ENABLED=true nohup "$UV" run python -m src.deriver > /tmp/coagent-honcho-deriver.log 2>&1 &
  ok "Memory deriver"

  # Terminal Canvas
  lsof -ti :3001 | xargs kill -9 2>/dev/null || true
  lsof -ti :5173 | xargs kill -9 2>/dev/null || true
  sleep 0.5
  cd "$CLI_DIR"
  HONCHO_BASE_URL="http://localhost:8000" HONCHO_API_KEY="local" nohup npm run dev > /tmp/coagent-terminal-canvas.log 2>&1 &
  for i in {1..15}; do
    PORT=$(grep -oE 'http://localhost:[0-9]+' /tmp/coagent-terminal-canvas.log 2>/dev/null | head -1 | grep -oE '[0-9]+$')
    [ -n "$PORT" ] && break
    sleep 1
  done
  PORT=${PORT:-5173}
  ok "Terminal Canvas"

  # Done
  echo ""
  echo -e "  ${BOLD}${GREEN}Ready!${RESET}  ${DIM}6 services running${RESET}"
  echo ""
  echo -e "  ${CYAN}  вћњ${RESET}  ${BOLD}http://localhost:$PORT${RESET}"
  echo ""
  echo -e "  ${DIM}  coagent status   health check${RESET}"
  echo -e "  ${DIM}  coagent logs     view logs${RESET}"
  echo -e "  ${DIM}  coagent stop     shut down${RESET}"
  echo ""

  open "http://localhost:$PORT" 2>/dev/null || true
}

# в”Ђв”Ђ Start (with wizard check) в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
do_start() {
  if [ ! -f "$SETUP_MARKER" ]; then
    do_wizard
  else
    do_start_services
  fi
}

# в”Ђв”Ђ Stop в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
do_stop() {
  echo -e "\n  ${DIM}Stopping CoAgent...${RESET}"

  lsof -ti :3001 | xargs kill -9 2>/dev/null || true
  lsof -ti :5173 | xargs kill -9 2>/dev/null || true
  lsof -ti :5174 | xargs kill -9 2>/dev/null || true
  lsof -ti :8000 | xargs kill -9 2>/dev/null || true
  pkill -f "src.deriver" 2>/dev/null || true
  cd "$HONCHO_DIR" 2>/dev/null && docker compose -f docker-compose.local.yml stop 2>&1 | grep -v "^$" || true

  echo -e "  ${GREEN}вњ“${RESET} All services stopped"
  echo ""
}

# в”Ђв”Ђ Status в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
do_status() {
  echo ""
  echo -e "  ${BOLD}CoAgent${RESET} services"
  echo ""

  PG=$(docker inspect --format='{{.State.Health.Status}}' honcho-database-1 2>/dev/null || echo "stopped")
  [ "$PG" = "healthy" ] && ok "Postgres     :5432" || fail "Postgres     :5432  ($PG)"

  RD=$(docker inspect --format='{{.State.Health.Status}}' honcho-redis-1 2>/dev/null || echo "stopped")
  [ "$RD" = "healthy" ] && ok "Redis        :6379" || fail "Redis        :6379  ($RD)"

  lsof -ti :8000 > /dev/null 2>&1 && ok "Honcho API   :8000" || fail "Honcho API   :8000"
  pgrep -f "src.deriver" > /dev/null 2>&1 && ok "Deriver      running" || fail "Deriver"
  lsof -ti :3001 > /dev/null 2>&1 && ok "Backend      :3001" || fail "Backend      :3001"

  PORT=""
  for p in 5173 5174 5175; do
    lsof -ti :$p > /dev/null 2>&1 && PORT=$p && break
  done
  [ -n "$PORT" ] && ok "Frontend     :$PORT" || fail "Frontend"
  echo ""
}

# в”Ђв”Ђ Logs в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
do_logs() {
  tail -f /tmp/coagent-honcho-api.log /tmp/coagent-honcho-deriver.log /tmp/coagent-terminal-canvas.log 2>/dev/null
}

# в”Ђв”Ђ Open в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
do_open() {
  for p in 5173 5174 5175; do
    lsof -ti :$p > /dev/null 2>&1 && open "http://localhost:$p" && exit 0
  done
  fail "Not running. Start with: coagent"
  exit 1
}

# в”Ђв”Ђ Main в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
case "${1:-start}" in
  start)   do_start ;;
  stop)    do_stop ;;
  status)  do_status ;;
  restart) do_stop; do_start_services ;;
  logs)    do_logs ;;
  open)    do_open ;;
  setup)   rm -f "$SETUP_MARKER"; do_wizard ;;
  help|-h|--help) usage ;;
  *)       echo "Unknown command: $1"; usage; exit 1 ;;
esac
