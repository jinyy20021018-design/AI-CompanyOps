#!/bin/bash
set -uo pipefail

CLI_DIR="$(cd "$(dirname "$0")/.." && pwd)"
SETUP_MARKER="$CLI_DIR/.coagent-setup-done"

_find_honcho() {
  [ -n "${COAGENT_HONCHO_DIR:-}" ] && [ -d "$COAGENT_HONCHO_DIR" ] && echo "$COAGENT_HONCHO_DIR" && return
  [ -d "$CLI_DIR/../honcho" ] && echo "$(cd "$CLI_DIR/../honcho" && pwd)" && return
  [ -d "$CLI_DIR/../../honcho" ] && echo "$(cd "$CLI_DIR/../../honcho" && pwd)" && return
  local p="$CLI_DIR"
  for _ in 1 2 3; do
    p="$(dirname "$p")"
    for d in "$p"/*/; do
      [ -f "${d}src/main.py" ] && [ -f "${d}docker-compose.local.yml" ] && echo "$(cd "$d" && pwd)" && return
    done
  done
  echo ""
}
HONCHO_DIR="$(_find_honcho)"

# ── Colors ────────────────────────────────────────
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
CYAN='\033[0;36m'
BLUE='\033[0;34m'
MAGENTA='\033[0;35m'
DIM='\033[2m'
BOLD='\033[1m'
RESET='\033[0m'

log()  { echo -e "  ${CYAN}▸${RESET} $1"; }
ok()   { echo -e "  ${GREEN}✓${RESET} $1"; }
fail() { echo -e "  ${RED}✗${RESET} $1"; }
warn() { echo -e "  ${YELLOW}!${RESET} $1"; }
head() { echo -e "\n${BOLD}$1${RESET}"; }

# ── Spinner ───────────────────────────────────────
spin() {
  local msg="$1"; shift
  local pid
  "$@" &>/dev/null &
  pid=$!
  local frames=("⠋" "⠙" "⠹" "⠸" "⠼" "⠴" "⠦" "⠧" "⠇" "⠏")
  local i=0
  while kill -0 "$pid" 2>/dev/null; do
    printf "\r  ${CYAN}${frames[$i]}${RESET} %s" "$msg"
    i=$(( (i + 1) % 10 ))
    sleep 0.1
  done
  wait "$pid" 2>/dev/null
  local rc=$?
  printf "\r"
  [ $rc -eq 0 ] && ok "$msg" || fail "$msg"
  return $rc
}

# ── Banner ────────────────────────────────────────
banner() {
  local P='\033[38;5;93m'    # deep purple
  local PD='\033[38;5;54m'   # dim purple
  local R="$RESET"
  local B="$BOLD"
  local D="$DIM"

  local lines=(
    "   ██████╗  ██████╗   █████╗   ██████╗  ███████╗ ███╗   ██╗ ████████╗"
    "  ██╔════╝ ██╔═══██╗ ██╔══██╗ ██╔════╝  ██╔════╝ ████╗  ██║ ╚══██╔══╝"
    "  ██║      ██║   ██║ ███████║ ██║  ███╗ █████╗   ██╔██╗ ██║    ██║   "
    "  ██║      ██║   ██║ ██╔══██║ ██║   ██║ ██╔══╝   ██║╚██╗██║    ██║   "
    "  ╚██████╗ ╚██████╔╝ ██║  ██║ ╚██████╔╝ ███████╗ ██║ ╚████║    ██║   "
    "   ╚═════╝  ╚═════╝  ╚═╝  ╚═╝  ╚═════╝  ╚══════╝ ╚═╝  ╚═══╝    ╚═╝   "
  )

  local glyphs=("░" "▒" "▓" "█" "╬" "╠" "╣" "╦" "╩" "┼" "┃" "━" "◆" "◇" "▪" "▫")
  local nglyphs=${#glyphs[@]}
  local nlines=${#lines[@]}
  local len=${#lines[0]}

  # Hide cursor
  printf '\033[?25l'

  # Print initial random garbage (all lines at once)
  echo ""
  for (( row=0; row<nlines; row++ )); do
    local garbage=""
    for (( col=0; col<len; col++ )); do
      local ch="${lines[$row]:$col:1}"
      if [ "$ch" = " " ]; then
        garbage+=" "
      else
        garbage+="${glyphs[$((RANDOM % nglyphs))]}"
      fi
    done
    echo -e "${PD}${garbage}${R}"
  done

  # Pure scramble phase — just random glyphs cycling, no locking yet
  local scramble_frames=12
  for (( frame=0; frame<scramble_frames; frame++ )); do
    printf "\033[${nlines}A"
    for (( row=0; row<nlines; row++ )); do
      local output=""
      local target="${lines[$row]}"
      for (( col=0; col<len; col++ )); do
        local ch="${target:$col:1}"
        if [ "$ch" = " " ]; then
          output+=" "
        else
          output+="${glyphs[$((RANDOM % nglyphs))]}"
        fi
      done
      echo -e "${PD}${output}${R}"
    done
    sleep 0.06
  done

  # Decode phase — characters lock in progressively
  local passes=10
  for (( pass=1; pass<=passes; pass++ )); do
    printf "\033[${nlines}A"
    local lock_ratio=$(( pass * 100 / passes ))

    for (( row=0; row<nlines; row++ )); do
      local output=""
      local target="${lines[$row]}"
      for (( col=0; col<len; col++ )); do
        local ch="${target:$col:1}"
        if [ "$ch" = " " ]; then
          output+=" "
        elif (( (RANDOM % 100) < lock_ratio )); then
          output+="${ch}"
        else
          output+="${glyphs[$((RANDOM % nglyphs))]}"
        fi
      done
      if (( pass >= passes - 2 )); then
        echo -e "${B}${P}${output}${R}"
      elif (( pass >= passes / 2 )); then
        echo -e "${P}${output}${R}"
      else
        echo -e "${PD}${output}${R}"
      fi
    done
    sleep 0.05
  done

  # Final clean pass — ensure 100% correct
  printf "\033[${nlines}A"
  for line in "${lines[@]}"; do
    echo -e "${B}${P}${line}${R}"
  done

  # Show cursor
  printf '\033[?25h'

  sleep 0.15

  # Tagline types in
  local tagline="Multi-agent terminal canvas with semantic memory"
  echo -ne "\n  ${D}"
  for (( i=0; i<${#tagline}; i++ )); do
    echo -n "${tagline:$i:1}"
    sleep 0.012
  done
  echo -e "${R}"

  # Sparkle
  echo -ne "  "
  local sparks=("·" "✧" "✦" "✧" "·")
  for s in "${sparks[@]}"; do
    echo -ne "${P}${s}${R} "
    sleep 0.06
  done
  echo ""
  echo ""
}

# ── First-run wizard ──────────────────────────────
do_wizard() {
  banner

  echo -e "${BOLD}  Welcome! Let's get you set up.${RESET}"
  echo -e "  ${DIM}This takes about 2 minutes. You'll only do this once.${RESET}"
  echo ""
  sleep 1

  # Step 1: Check prerequisites
  head "  Step 1/5  Checking prerequisites"
  sleep 0.3

  local missing=0
  if command -v node &>/dev/null; then
    local node_major
    node_major=$(node -v | grep -oE '[0-9]+' | head -1)
    if [ "$node_major" -lt 20 ] || [ "$node_major" -gt 24 ]; then
      fail "Node.js $(node -v) — requires v20–v24"
      echo -e "    ${DIM}Recommended: install nvm and switch versions:${RESET}"
      echo -e "    ${CYAN}curl -o- https://raw.githubusercontent.com/nvm-sh/nvm/v0.40.1/install.sh | bash${RESET}"
      echo -e "    ${CYAN}nvm install 22 && nvm use 22${RESET}"
      missing=1
    else
      ok "Node.js $(node -v)"
    fi
  else
    fail "Node.js not found — requires v20–v24"
    echo -e "    ${DIM}Install via nvm (recommended):${RESET}"
    echo -e "    ${CYAN}curl -o- https://raw.githubusercontent.com/nvm-sh/nvm/v0.40.1/install.sh | bash${RESET}"
    echo -e "    ${CYAN}nvm install 22${RESET}"
    missing=1
  fi
  command -v docker &>/dev/null && ok "Docker $(docker --version 2>/dev/null | grep -oE '[0-9]+\.[0-9]+\.[0-9]+')" || { fail "Docker not found — install Docker Desktop"; missing=1; }

  if [ ! -d "$HONCHO_DIR" ] || [ -z "$HONCHO_DIR" ]; then
    warn "Honcho server not found"
    echo -e "    ${DIM}CoAgent needs the Honcho memory server to run.${RESET}"
    echo -e "    ${DIM}We'll clone it as a sibling directory (one-time, ~30 seconds).${RESET}"
    echo ""
    echo -ne "  ${YELLOW}Clone Honcho now? [Y/n]:${RESET} "
    read -r clone_answer
    if [[ "$clone_answer" =~ ^[Nn] ]]; then
      echo ""
      echo -e "  ${DIM}Clone it manually:${RESET}"
      echo -e "  ${CYAN}git clone https://github.com/plastic-labs/honcho.git ${CLI_DIR}/../honcho${RESET}"
      echo -e "  ${DIM}Or set: export COAGENT_HONCHO_DIR=/path/to/honcho${RESET}"
      exit 1
    fi
    echo ""
    log "Cloning Honcho..."
    if git clone --quiet https://github.com/plastic-labs/honcho.git "${CLI_DIR}/../honcho" 2>/dev/null; then
      HONCHO_DIR="$(cd "${CLI_DIR}/../honcho" && pwd)"
      ok "Honcho cloned to ${DIM}${HONCHO_DIR}${RESET}"
    else
      fail "Clone failed. Check your internet connection and try:"
      echo -e "    ${CYAN}git clone https://github.com/plastic-labs/honcho.git ${CLI_DIR}/../honcho${RESET}"
      missing=1
    fi
  else
    ok "Honcho server found"
  fi

  [ $missing -eq 1 ] && { echo ""; fail "Fix the above and try again."; exit 1; }

  # Step 2: Anthropic API key
  head "  Step 2/5  Anthropic API key"
  sleep 0.3

  local anthropic_api_key=""
  local auth_file="$CLI_DIR/.coagent-auth"

  # Reuse existing key if already saved.
  if [ -f "$auth_file" ]; then
    anthropic_api_key=$(grep "^ANTHROPIC_API_KEY=" "$auth_file" 2>/dev/null | cut -d= -f2-)
  fi

  if [ -n "$anthropic_api_key" ] && [ "$anthropic_api_key" != "" ]; then
    ok "Anthropic API key found  ${DIM}${anthropic_api_key:0:12}...${RESET}"
  else
    echo -e "  ${DIM}CoAgent uses an Anthropic API key for both agents and memory services.${RESET}"
    echo -e "  ${DIM}Get it at: ${BOLD}https://console.anthropic.com/settings/keys${RESET}"
    echo ""
    echo -ne "  ${YELLOW}Paste your Anthropic API key:${RESET} "
    read -r input_api_key
    if [ -z "$input_api_key" ]; then
      fail "No key provided — agents cannot run without one."
      exit 1
    fi
    anthropic_api_key="$input_api_key"
    ok "API key saved  ${DIM}${anthropic_api_key:0:12}...${RESET}"
  fi
  printf 'ANTHROPIC_API_KEY=%s\n' "$anthropic_api_key" > "$auth_file"
  chmod 600 "$auth_file"

  # Step 3: Gemini API key
  head "  Step 3/5  Embedding model"
  sleep 0.3

  local gemini_key=""
  if [ -n "$HONCHO_DIR" ] && [ -f "$HONCHO_DIR/.env" ]; then
    gemini_key=$(grep "^LLM_GEMINI_API_KEY=" "$HONCHO_DIR/.env" 2>/dev/null | cut -d= -f2)
  fi

  if [ -n "$gemini_key" ] && [ "$gemini_key" != "" ] && [ "$gemini_key" != "your-key-here" ]; then
    ok "Gemini API key configured  ${DIM}${gemini_key:0:10}...${RESET}"
  else
    echo -e "  ${DIM}CoAgent needs an embedding model for semantic memory.${RESET}"
    echo -e "  ${DIM}Google Gemini is free — no credit card needed.${RESET}"
    echo ""
    echo -e "  ${BOLD}Get your key:${RESET} ${CYAN}https://aistudio.google.com/apikey${RESET}"
    echo ""
    echo -ne "  ${YELLOW}Paste your Gemini API key (or Enter to skip):${RESET} "
    read -r input_key
    if [ -n "$input_key" ]; then
      gemini_key="$input_key"
      ok "Gemini key saved"
    else
      warn "Skipped — semantic search won't work without embeddings"
      echo -e "    ${DIM}Add later: edit $HONCHO_DIR/.env${RESET}"
    fi
  fi

  # Step 4: Install dependencies
  head "  Step 4/5  Installing dependencies"
  sleep 0.3

  # uv
  UV="${HOME}/.local/bin/uv"
  if [ ! -x "$UV" ] && ! command -v uv &>/dev/null; then
    spin "Installing uv (Python package manager)" curl -LsSf https://astral.sh/uv/install.sh -o /tmp/uv-install.sh
    bash /tmp/uv-install.sh &>/dev/null
    ok "uv installed"
  else
    [ ! -x "$UV" ] && UV="$(command -v uv)"
    ok "uv ready"
  fi

  # npm
  if [ ! -d "$CLI_DIR/backend/node_modules" ]; then
    spin "Installing dependencies" bash -c "cd '$CLI_DIR' && npm install --silent 2>/dev/null && cd backend && npm install --silent 2>/dev/null && cd ../frontend && npm install --silent 2>/dev/null"
  else
    ok "Node dependencies ready"
  fi

  # Verify node-pty native module (critical for terminal spawning)
  if ! node -e "require('$CLI_DIR/backend/node_modules/node-pty')" 2>/dev/null; then
    warn "node-pty native module needs building..."
    log "Attempting auto-fix (this may take ~30 seconds)..."
    cd "$CLI_DIR/backend"

    # Strategy 1: npm rebuild
    npm rebuild node-pty 2>/dev/null
    if node -e "require('$CLI_DIR/backend/node_modules/node-pty')" 2>/dev/null; then
      ok "node-pty fixed via npm rebuild"
    else
      # Strategy 2: clean reinstall of node-pty
      log "Rebuild failed, trying clean reinstall..."
      rm -rf node_modules/node-pty
      npm install node-pty 2>/dev/null
      if node -e "require('$CLI_DIR/backend/node_modules/node-pty')" 2>/dev/null; then
        ok "node-pty fixed via clean reinstall"
      else
        # Strategy 3: node-gyp rebuild
        log "Reinstall failed, trying node-gyp..."
        npx node-gyp rebuild --directory=node_modules/node-pty 2>/dev/null
        if node -e "require('$CLI_DIR/backend/node_modules/node-pty')" 2>/dev/null; then
          ok "node-pty fixed via node-gyp rebuild"
        else
          fail "node-pty compilation failed — terminals won't work"
          echo -e "    ${DIM}Your Node.js version: $(node -v)${RESET}"
          echo -e "    ${DIM}Try installing Node.js v22 LTS: https://nodejs.org${RESET}"
        fi
      fi
    fi
    cd "$CLI_DIR"
  else
    ok "node-pty native module ready"
  fi

  # python
  if [ -n "$HONCHO_DIR" ] && [ ! -d "$HONCHO_DIR/.venv" ]; then
    spin "Installing Honcho Python dependencies" bash -c "cd '$HONCHO_DIR' && '$UV' sync --quiet 2>/dev/null"
  else
    ok "Python dependencies ready"
  fi

  # Step 5: Configure .env
  head "  Step 5/5  Writing configuration"
  sleep 0.3

  if [ -n "$HONCHO_DIR" ]; then
    # Create or update .env
    if [ ! -f "$HONCHO_DIR/.env" ]; then
      cp "$CLI_DIR/.env.example" "$HONCHO_DIR/.env"
    fi

    # Inject Gemini key
    if [ -n "$gemini_key" ]; then
      if grep -q "^LLM_GEMINI_API_KEY=" "$HONCHO_DIR/.env"; then
        sed -i '' "s|^LLM_GEMINI_API_KEY=.*|LLM_GEMINI_API_KEY=$gemini_key|" "$HONCHO_DIR/.env"
      else
        echo "LLM_GEMINI_API_KEY=$gemini_key" >> "$HONCHO_DIR/.env"
      fi
    fi

    # Inject Anthropic API key into Honcho .env (used by deriver/summary/dream).
    if [ -n "$anthropic_api_key" ]; then
      if grep -q "^LLM_ANTHROPIC_API_KEY=" "$HONCHO_DIR/.env"; then
        sed -i '' "s|^LLM_ANTHROPIC_API_KEY=.*|LLM_ANTHROPIC_API_KEY=$anthropic_api_key|" "$HONCHO_DIR/.env"
      else
        echo "LLM_ANTHROPIC_API_KEY=$anthropic_api_key" >> "$HONCHO_DIR/.env"
      fi
    fi

    ok "Configuration saved"
  fi

  # Mark setup done
  touch "$SETUP_MARKER"

  echo ""
  echo -e "  ${BOLD}${GREEN}Setup complete!${RESET}"
  echo ""
  sleep 0.5

  # Now start everything
  do_start_services
}

# ── Usage ─────────────────────────────────────────
usage() {
  echo -e "${BOLD}CoAgent${RESET} — Multi-agent terminal canvas with semantic memory"
  echo ""
  echo "Usage: coagent [command]"
  echo ""
  echo "Commands:"
  echo "  (default)   Start all services (sandbox mode — each agent in its own container)"
  echo "  stop        Stop all services + reap orphan agent containers"
  echo "  status      Show service health"
  echo "  restart     Stop then start"
  echo "  logs        Tail all service logs"
  echo "  open        Open the UI in browser"
  echo "  setup       Re-run first-time setup"
  echo ""
  echo "Environment overrides:"
  echo "  COAGENT_MODE=pty                    use legacy host-PTY mode (no per-agent containers)"
  echo "  COAGENT_HOST_PROJECTS_ROOT=...      host dir bind-mounted into agents (default: project parent)"
  echo ""
}

# ── UV path ───────────────────────────────────────
UV="${HOME}/.local/bin/uv"
[ ! -x "$UV" ] && UV="$(command -v uv 2>/dev/null || echo "")"

# ── Start services ────────────────────────────────
do_start_services() {
  banner
  echo -e "  ${DIM}Starting services...${RESET}"

  # Load API key (set during the wizard).
  local auth_file="$CLI_DIR/.coagent-auth"
  local anthropic_api_key=""
  if [ -f "$auth_file" ]; then
    anthropic_api_key=$(grep "^ANTHROPIC_API_KEY=" "$auth_file" | cut -d= -f2-)
  fi
  if [ -z "$anthropic_api_key" ]; then
    fail "ANTHROPIC_API_KEY not configured. Run: ./bin/coagent-cli setup"
    exit 1
  fi
  export ANTHROPIC_API_KEY="$anthropic_api_key"
  ok "Auth: Anthropic API key  ${DIM}${anthropic_api_key:0:12}...${RESET}"

  # Docker
  if ! docker info &>/dev/null; then
    fail "Docker is not running. Start Docker Desktop first."
    exit 1
  fi
  cd "$CLI_DIR"

  # Mode selection. Default = container (sandboxed agents).
  # Override with COAGENT_MODE=pty for the legacy host-PTY mode.
  local coagent_mode="${COAGENT_MODE:-container}"

  # Use a temp file so we can both stream logs and capture the exit code (a pipe
  # would mask compose failures behind `grep` / `while read`).
  local compose_log
  compose_log=$(mktemp)
  if [ "$coagent_mode" = "container" ]; then
    export COAGENT_HOST_PROJECTS_ROOT="${COAGENT_HOST_PROJECTS_ROOT:-$(cd "$CLI_DIR/.." && pwd)}"
    docker compose -f docker-compose.yml --profile container up -d > "$compose_log" 2>&1
  else
    docker compose -f docker-compose.yml up -d postgres redis > "$compose_log" 2>&1
  fi
  local compose_rc=$?
  grep -E "Started|Running|Creating" "$compose_log" 2>/dev/null | while read line; do log "$line"; done
  if [ $compose_rc -ne 0 ]; then
    fail "docker compose up failed (rc=$compose_rc). Full output:"
    cat "$compose_log" >&2
    rm -f "$compose_log"
    exit 1
  fi
  rm -f "$compose_log"

  for i in {1..20}; do
    PG=$(docker inspect --format='{{.State.Health.Status}}' coagent-database-1 2>/dev/null || echo "waiting")
    RD=$(docker inspect --format='{{.State.Health.Status}}' coagent-redis-1 2>/dev/null || echo "waiting")
    [ "$PG" = "healthy" ] && [ "$RD" = "healthy" ] && break
    sleep 1
  done
  if [ "$PG" = "healthy" ] && [ "$RD" = "healthy" ]; then
    ok "Postgres + Redis"
  else
    fail "Postgres or Redis did not become healthy (PG=$PG RD=$RD)"
    exit 1
  fi

  # DB migrations (first run after Docker)
  if [ -f "$HONCHO_DIR/alembic.ini" ]; then
    cd "$HONCHO_DIR" && "$UV" run alembic upgrade head &>/dev/null
  fi

  # Honcho API
  lsof -ti :8000 | xargs kill -9 2>/dev/null || true
  sleep 0.5
  cd "$HONCHO_DIR"
  nohup "$UV" run fastapi dev src/main.py --port 8000 > /tmp/coagent-honcho-api.log 2>&1 &
  for i in {1..20}; do
    curl -sf http://localhost:8000/v3/workspaces -X POST -H "Content-Type: application/json" -d '{"id":"terminal-canvas"}' > /dev/null 2>&1 && break
    sleep 1
  done
  ok "Honcho API"

  # Deriver
  pkill -f "src.deriver" 2>/dev/null || true
  sleep 0.5
  DERIVER_FLUSH_ENABLED=true nohup "$UV" run python -m src.deriver > /tmp/coagent-honcho-deriver.log 2>&1 &
  ok "Memory deriver"

  if [ "$coagent_mode" = "container" ]; then
    # Backend runs in the orchestrator container (already started above).
    local orchestrator_up=0
    for i in {1..30}; do
      curl -sf "http://localhost:3001/" -o /dev/null 2>/dev/null && { orchestrator_up=1; break; }
      sleep 1
    done
    if [ $orchestrator_up -eq 1 ]; then
      ok "Orchestrator (container)"
    else
      fail "Orchestrator did not become reachable on :3001"
      docker logs coagent-orchestrator-1 --tail 30 2>&1 >&2
      exit 1
    fi
  else
    # Backend native (Phase A/B path).
    lsof -ti :3001 | xargs kill -9 2>/dev/null || true
    sleep 0.5
    cd "$CLI_DIR"
    HONCHO_BASE_URL="http://localhost:8000" HONCHO_API_KEY="local" nohup npm run dev:backend > /tmp/coagent-terminal-canvas.log 2>&1 &
    local backend_up=0
    for i in {1..15}; do
      grep -qE "listening on (port )?3001|on :3001|http://localhost:3001" /tmp/coagent-terminal-canvas.log 2>/dev/null && { backend_up=1; break; }
      sleep 1
    done
    if [ $backend_up -eq 1 ]; then
      ok "Backend (host)"
    else
      fail "Backend did not start. Tail of /tmp/coagent-terminal-canvas.log:"
      tail -20 /tmp/coagent-terminal-canvas.log >&2
      exit 1
    fi
  fi

  # Frontend (Docker) — already created with --profile container in container mode.
  if [ "$coagent_mode" != "container" ]; then
    cd "$CLI_DIR"
    docker compose -f docker-compose.yml up -d frontend > /tmp/coagent-frontend.log 2>&1 \
      || { fail "frontend up failed:"; cat /tmp/coagent-frontend.log >&2; exit 1; }
  fi
  # Verify frontend is actually serving.
  PORT=5173
  local fe_up=0
  for i in {1..15}; do
    curl -sf "http://localhost:$PORT/" -o /dev/null 2>/dev/null && { fe_up=1; break; }
    sleep 1
  done
  if [ $fe_up -eq 1 ]; then
    ok "Frontend"
  else
    fail "Frontend did not respond on :$PORT"
    docker logs coagent-frontend-1 --tail 30 2>&1 >&2
    exit 1
  fi

  # Done
  echo ""
  echo -e "  ${BOLD}${GREEN}Ready!${RESET}  ${DIM}6 services running${RESET}"
  echo ""
  echo -e "  ${CYAN}  ➜${RESET}  ${BOLD}http://localhost:$PORT${RESET}"
  echo ""
  echo -e "  ${DIM}  coagent status   health check${RESET}"
  echo -e "  ${DIM}  coagent logs     view logs${RESET}"
  echo -e "  ${DIM}  coagent stop     shut down${RESET}"
  echo ""

  open "http://localhost:$PORT" 2>/dev/null || true
}

# ── Start (with wizard check) ─────────────────────
do_start() {
  if [ ! -f "$SETUP_MARKER" ]; then
    do_wizard
  else
    do_start_services
  fi
}

# ── Stop ──────────────────────────────────────────
do_stop() {
  echo -e "\n  ${DIM}Stopping CoAgent...${RESET}"

  lsof -ti :3001 | xargs kill -9 2>/dev/null || true
  lsof -ti :8000 | xargs kill -9 2>/dev/null || true
  pkill -f "src.deriver" 2>/dev/null || true
  cd "$CLI_DIR" && docker compose -f docker-compose.yml --profile container stop 2>&1 | grep -v "^$" || true
  # Best-effort cleanup of any orphaned agent containers from a crashed orchestrator.
  docker ps -aq --filter "label=coagent.managed=true" | xargs -r docker rm -f >/dev/null 2>&1 || true

  echo -e "  ${GREEN}✓${RESET} All services stopped"
  echo ""
}

# ── Status ────────────────────────────────────────
do_status() {
  echo ""
  echo -e "  ${BOLD}CoAgent${RESET} services"
  echo ""

  PG=$(docker inspect --format='{{.State.Health.Status}}' coagent-database-1 2>/dev/null || echo "stopped")
  [ "$PG" = "healthy" ] && ok "Postgres     :5432" || fail "Postgres     :5432  ($PG)"

  RD=$(docker inspect --format='{{.State.Health.Status}}' coagent-redis-1 2>/dev/null || echo "stopped")
  [ "$RD" = "healthy" ] && ok "Redis        :6379" || fail "Redis        :6379  ($RD)"

  lsof -ti :8000 > /dev/null 2>&1 && ok "Honcho API   :8000" || fail "Honcho API   :8000"
  pgrep -f "src.deriver" > /dev/null 2>&1 && ok "Deriver      running" || fail "Deriver"
  lsof -ti :3001 > /dev/null 2>&1 && ok "Backend      :3001" || fail "Backend      :3001"

  FE=$(docker inspect --format='{{.State.Status}}' coagent-frontend-1 2>/dev/null || echo "stopped")
  [ "$FE" = "running" ] && ok "Frontend     :5173" || fail "Frontend     :5173  ($FE)"
  echo ""
}

# ── Logs ──────────────────────────────────────────
do_logs() {
  tail -f /tmp/coagent-honcho-api.log /tmp/coagent-honcho-deriver.log /tmp/coagent-terminal-canvas.log 2>/dev/null
}

# ── Open ──────────────────────────────────────────
do_open() {
  for p in 5173 5174 5175; do
    lsof -ti :$p > /dev/null 2>&1 && open "http://localhost:$p" && exit 0
  done
  fail "Not running. Start with: coagent"
  exit 1
}

# ── Main ──────────────────────────────────────────
case "${1:-start}" in
  start)   do_start ;;
  stop)    do_stop ;;
  status)  do_status ;;
  restart) do_stop; do_start_services ;;
  logs)    do_logs ;;
  open)    do_open ;;
  setup)   rm -f "$SETUP_MARKER"; do_wizard ;;
  help|-h|--help) usage ;;
  *)       echo "Unknown command: $1"; usage; exit 1 ;;
esac
