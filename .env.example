# CoAgent Terminal Canvas — Environment Variables
# Copy to the honcho directory as .env:  cp .env.example ../honcho/.env

# ── Anthropic (auto-filled by coagent start from Claude Code keychain) ──
# No manual setup needed if you have Claude Code installed.
# The OAuth token is refreshed automatically on every `coagent start`.
LLM_ANTHROPIC_API_KEY=

# ── Embeddings (required — pick one) ──
# Option A: Google Gemini (free, recommended)
#   Get a free key at: https://aistudio.google.com/apikey
LLM_GEMINI_API_KEY=
LLM_EMBEDDING_PROVIDER=gemini

# Option B: OpenAI (~$0.02/1M tokens)
# LLM_OPENAI_API_KEY=
# LLM_EMBEDDING_PROVIDER=openai

# ── Database (auto-configured by Docker) ──
DB_CONNECTION_URI=postgresql+psycopg://postgres:postgres@localhost:5432/postgres

# ── Cache ──
CACHE_ENABLED=true
CACHE_URL=redis://localhost:6379/0

# ── Auth (disabled for local use) ──
AUTH_USE_AUTH=false

# ── Vector Store ──
VECTOR_STORE_TYPE=pgvector

# ── All LLM agents use Claude Haiku (cheapest) ──
DERIVER_PROVIDER=anthropic
DERIVER_MODEL=claude-haiku-4-5-20251001
SUMMARY_PROVIDER=anthropic
SUMMARY_MODEL=claude-haiku-4-5-20251001
DREAM_PROVIDER=anthropic
DREAM_MODEL=claude-haiku-4-5-20251001
