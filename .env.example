# CoAgent — Environment Variables (API-key-only mode)
#
# Copy to project root as `.env` (read by docker compose for ${VAR} substitution)
# AND/OR copy to the honcho directory as `.env`:  cp .env.example ../honcho/.env

# ── Anthropic API key (required) ─────────────────────────────────────────────
# Get one at: https://console.anthropic.com/settings/keys
# Used by:
#   - Each spawned agent's claude CLI (in container mode)
#   - Honcho deriver/summary/dream services (LLM_ANTHROPIC_API_KEY below)
ANTHROPIC_API_KEY=
LLM_ANTHROPIC_API_KEY=

# ── Embeddings (required for semantic recall — pick one) ─────────────────────
# Option A: Google Gemini (free; recommended)
#   Get a free key at: https://aistudio.google.com/apikey
LLM_GEMINI_API_KEY=
LLM_EMBEDDING_PROVIDER=gemini

# Option B: OpenAI (~$0.02/1M tokens)
# LLM_OPENAI_API_KEY=
# LLM_EMBEDDING_PROVIDER=openai

# ── Database (auto-configured by Docker) ─────────────────────────────────────
DB_CONNECTION_URI=postgresql+psycopg://postgres:postgres@localhost:5432/postgres

# ── Cache ────────────────────────────────────────────────────────────────────
CACHE_ENABLED=true
CACHE_URL=redis://localhost:6379/0

# ── Auth (disabled for local use) ────────────────────────────────────────────
AUTH_USE_AUTH=false

# ── Vector Store ─────────────────────────────────────────────────────────────
VECTOR_STORE_TYPE=pgvector

# ── All Honcho LLM services use Claude Haiku (cheapest) ──────────────────────
DERIVER_PROVIDER=anthropic
DERIVER_MODEL=claude-haiku-4-5-20251001
SUMMARY_PROVIDER=anthropic
SUMMARY_MODEL=claude-haiku-4-5-20251001
DREAM_PROVIDER=anthropic
DREAM_MODEL=claude-haiku-4-5-20251001

# ── Container mode (Phase C+) ────────────────────────────────────────────────
# Required when running `COAGENT_MODE=container ./bin/coagent-cli`.
# Host path that is the parent of every project folder you'll add in CoAgent.
# Example: /Users/you/Downloads/project
# COAGENT_HOST_PROJECTS_ROOT=
